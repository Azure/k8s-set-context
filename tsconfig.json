{
   "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "skipLibCheck": true,
      "strict": true,
      "outDir": "dist",
      "rootDir": "src"
   },
   "include": ["src"],
   "exclude": ["node_modules", "src/**/*.test.ts"]
}
